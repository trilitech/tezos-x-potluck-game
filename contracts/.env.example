# Copy to `.env` for Hardhat deploy scripts. Never commit `.env`.

# Pick stack: `testnet` (demo txpark) or `previewnet` (unless TEZOSX_EVM_RPC / TEZOSX_CHAIN_ID override).
TEZOSX_NETWORK=testnet

# Optional overrides (defaults come from TEZOSX_NETWORK).
# TEZOSX_EVM_RPC=https://evm.previewnet.tezosx.nomadic-labs.com
# TEZOSX_CHAIN_ID=128064

DEPLOYER_PRIVATE_KEY=

# After deploy-usdc.ts
# USDC_ADDRESS=

USDC_INITIAL_SUPPLY=1000000000000

# Optional: escrow deploy / relayer (not read by Hardhat config)
# POT_ADDRESS=
# GAME_KT1=

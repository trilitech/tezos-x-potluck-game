# Copy to `.env`. Never commit `.env`.

# `testnet` | `previewnet` — selects default RPCs, chain id, explorers, tzkt API, and **which contract-address block** below is used.
VITE_TEZOSX_NETWORK=testnet

# --- Previewnet contracts (used when VITE_TEZOSX_NETWORK=previewnet) ---
# Falls back to VITE_USDC_ADDRESS / VITE_POT_ADDRESS / VITE_GAME_CONTRACT, then built-in Previewnet defaults.
# Required for the active stack (stack-specific first, then legacy VITE_USDC_* as fallback).
VITE_PREVIEWNET_USDC_ADDRESS=
VITE_PREVIEWNET_POT_ADDRESS=
VITE_PREVIEWNET_GAME_CONTRACT=

VITE_TESTNET_USDC_ADDRESS=
VITE_TESTNET_POT_ADDRESS=
VITE_TESTNET_GAME_CONTRACT=

# Required: CRAC gateway (stack-specific optional; else this must be set).
VITE_CRAC_PRECOMPILE=0xff00000000000000000000000000000000000007
# VITE_PREVIEWNET_CRAC_PRECOMPILE=
# VITE_TESTNET_CRAC_PRECOMPILE=

# Legacy second choice after VITE_PREVIEWNET_* / VITE_TESTNET_*.
# VITE_USDC_ADDRESS=
# VITE_POT_ADDRESS=
# VITE_GAME_CONTRACT=

# Optional overrides (defaults from VITE_TEZOSX_NETWORK).
# VITE_EVM_RPC=https://demo.txpark.nomadic-labs.com/rpc
# VITE_TEZLINK_RPC=https://demo.txpark.nomadic-labs.com/rpc/tezlink
# VITE_CHAIN_ID=127124
# VITE_EVM_EXPLORER_URL=https://demo-blockscout.txpark.nomadic-labs.com
# VITE_TEZOS_EXPLORER_BASE=https://sandbox.tezlink.tzkt.io
# VITE_TZKT_API_URL=https://demo.txpark.nomadic-labs.com/tzkt

# Optional: footer Docs / Michelson-interface marketing links (defaults: tezos.com/tezos-x, tezlink.tezos.com)
# VITE_DOCS_URL=https://tezos.com/tezos-x/
# VITE_TEZLINK_SITE_URL=https://tezlink.tezos.com/

VITE_USDC_DECIMALS=6
VITE_PRESS_AMOUNT=1
VITE_POLL_INTERVAL_MS=5000
# After an EVM deposit confirms, max time (ms) to wait for Michelson-side pot to increase (default 40000 = 40s)
# VITE_GAME_STATE_WAIT_TIMEOUT_MS=40000
# Optional: footer Faucet link
# VITE_FAUCET_URL=https://demo-faucet.txpark.nomadic-labs.com/
# Optional: override the hosted starter-airdrop endpoint if needed.
# VITE_AIRDROP_API_URL=https://tezosx-evm-usdc-airdrop.vercel.app/api/airdrop
# Optional: tzkt “operations” path segment if not the game KT1 (e.g. Tezos X rollup id for …/BLS2…/operations)
# VITE_TEZKT_GAME_OPERATIONS_PATH=BLS2c5DY83fjmPtuLBf66yJrmCcmYHXtP4BR33jBjufjyM2wrgA

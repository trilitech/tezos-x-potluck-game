# Copy to .env and fill in. Never commit .env (see root .gitignore).

VITE_EVM_RPC=https://demo.txpark.nomadic-labs.com/rpc
VITE_TEZLINK_RPC=https://demo.txpark.nomadic-labs.com/rpc/tezlink
# Optional: override explorer URLs for address links (defaults work with demo txpark)
# VITE_EVM_EXPLORER_URL=https://demo-blockscout.txpark.nomadic-labs.com
# VITE_TEZOS_EXPLORER_BASE=https://sandbox.tezlink.tzkt.io

VITE_CHAIN_ID=127124

# Must match your EVM deployments and the relayer env (same USDC, pot, game KT1)
VITE_USDC_ADDRESS=
VITE_POT_ADDRESS=
VITE_GAME_CONTRACT=

VITE_USDC_DECIMALS=6
VITE_PRESS_AMOUNT=1
VITE_POLL_INTERVAL_MS=5000
# After an EVM deposit confirms, max time (ms) to wait for Tezlink pot to increase (default 40000 = 40s)
# VITE_GAME_STATE_WAIT_TIMEOUT_MS=40000
# Optional: Wallet-section faucet link (defaults to hosted TezosX EVM tap if unset)
# VITE_FAUCET_URL=https://tezosx-evm-usdc-airdrop.vercel.app/

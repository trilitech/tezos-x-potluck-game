# Copy to `.env`. Never commit `.env`.

VITE_TEZOSX_NETWORK=previewnet

# Own Michelson counter (optional on previewnet — app has a tutorial default KT1).
# On Previewnet the counter value is loaded from the TzKT API URL in presets (api.previewnet.tezosx.tzkt.io).
# VITE_COUNTER_KT1=
# VITE_PREVIEWNET_COUNTER_KT1=

# Testnet (when VITE_TEZOSX_NETWORK=testnet):
# VITE_EVM_RPC=https://demo.txpark.nomadic-labs.com/rpc
# VITE_TEZLINK_RPC=https://demo.txpark.nomadic-labs.com/rpc/tezlink
# VITE_CHAIN_ID=127124
# VITE_EVM_EXPLORER_URL=https://demo-blockscout.txpark.nomadic-labs.com
# VITE_TEZOS_EXPLORER_BASE=https://sandbox.tezlink.tzkt.io
# VITE_TZKT_API_URL=https://demo.txpark.nomadic-labs.com/tzkt

VITE_POLL_INTERVAL_MS=5000

# Optional: same starter airdrop API as xbutton-frontend (default: hosted Vercel app). Server holds funded keys.
# VITE_AIRDROP_API_URL=https://tezosx-evm-usdc-airdrop.vercel.app/api/airdrop

# Deployed EvmToMichelsonCounter (must use same KT1 as above).
VITE_COUNTER_WRAPPER_ADDRESS=
VITE_DOCS_URL=https://x.tezos.com/docs/
# VITE_TEZOS_X_EXPLORE_URL=https://tezos.com/tezos-x/

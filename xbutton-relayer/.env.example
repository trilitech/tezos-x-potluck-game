# Copy to `.env`. Never commit `.env`.

# Flip to `previewnet` for Previewnet RPC presets and **built-in Previewnet pot/game** (POT_ADDRESS / GAME_KT1 stay for testnet).
# On previewnet, `EVM_RPC` and `TEZLINK_RPC` are ignored so stale testnet values cannot break the relayer.
#
# Previewnet reference (when TEZOSX_NETWORK=previewnet the relayer uses these URLs; EVM chainId must be 128064):
#   EVM JSON-RPC     https://evm.previewnet.tezosx.nomadic-labs.com     CAIP-2 eip155:128064
#   Michelson RPC    https://michelson.previewnet.tezosx.nomadic-labs.com   tezos:NetXY2oPPzkxUW1
#   Blockscout       https://blockscout.previewnet.tezosx.nomadic-labs.com
#   TzKT             https://tzkt.previewnet.tezosx.nomadic-labs.com
#   Faucet           https://faucet.previewnet.tezosx.nomadic-labs.com
TEZOSX_NETWORK=testnet

RELAYER_PRIVATE_KEY=

# Testnet stack: classic envs (optional; built-in testnet defaults if unset).
POT_ADDRESS=
GAME_KT1=

# Optional: only if you redeploy Previewnet and need overrides.
# PREVIEWNET_POT_ADDRESS=
# PREVIEWNET_GAME_KT1=

# Optional second choice for testnet only.
# TESTNET_POT_ADDRESS=
# TESTNET_GAME_KT1=

# Optional; defaults to standard CRAC precompile on Tezos X demos.
# CRAC_PRECOMPILE=0xff00000000000000000000000000000000000007

# Optional overrides (testnet only; ignored when TEZOSX_NETWORK=previewnet).
# EVM_RPC=https://demo.txpark.nomadic-labs.com/rpc
# TEZLINK_RPC=https://demo.txpark.nomadic-labs.com/rpc/tezlink

# Optional: log every poll (fromBlock, log count) so the terminal is not silent when no events match POT_ADDRESS
# RELAYER_VERBOSE_POLL=1
# Optional: log each claim/payout scan (Michelson storage snapshot + payout steps)
# RELAYER_VERBOSE_CLAIM=1

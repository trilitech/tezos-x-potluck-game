# Copy to `.env`. Never commit `.env`.

# `testnet` | `previewnet` — selects default EVM + Michelson RPCs and **which pot/game block** below is used.
TEZOSX_NETWORK=testnet

# --- Previewnet (used when TEZOSX_NETWORK=previewnet) ---
# Then TESTNET_* / POT_ADDRESS / GAME_KT1, then built-in Previewnet defaults.
PREVIEWNET_POT_ADDRESS=
PREVIEWNET_GAME_KT1=
# PREVIEWNET_CRAC_PRECOMPILE=0xff00000000000000000000000000000000000007

# --- Testnet (used when TEZOSX_NETWORK=testnet) ---
TESTNET_POT_ADDRESS=
TESTNET_GAME_KT1=
# TESTNET_CRAC_PRECOMPILE=0xff00000000000000000000000000000000000007

# Legacy (second choice after stack-specific vars).
# POT_ADDRESS=
# GAME_KT1=

# Optional overrides (defaults from TEZOSX_NETWORK).
# EVM_RPC=https://demo.txpark.nomadic-labs.com/rpc
# TEZLINK_RPC=https://demo.txpark.nomadic-labs.com/rpc/tezlink

RELAYER_PRIVATE_KEY=

CRAC_PRECOMPILE=0xff00000000000000000000000000000000000007

# Optional: log every poll (fromBlock, log count) so the terminal is not silent when no events match POT_ADDRESS
# RELAYER_VERBOSE_POLL=1
# Optional: log each claim/payout scan (Michelson storage snapshot + payout steps)
# RELAYER_VERBOSE_CLAIM=1
